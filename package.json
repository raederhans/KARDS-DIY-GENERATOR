{
  "name": "kards-card-forge",
  "private": true,
  "version": "1.3.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "local": "node tools/start-local.mjs",
    "samples:bilingual": "node tools/generate_bilingual_sample_assets.mjs",
    "samples:bilingual:check": "node tools/generate_bilingual_sample_assets.mjs --check",
    "samples:hq:en": "node tools/generate_bilingual_hq_references.mjs",
    "samples:hq:en:check": "node tools/generate_bilingual_hq_references.mjs --check",
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && npm run build:verified",
    "build:verified": "vite build && npm run verify:dist-private-boundary",
    "build:sites": "npm run typecheck && vite build && node tools/prepare_sites_dist.mjs && npm run verify:dist-private-boundary",
    "test": "vitest run --exclude .runtime/**",
    "smoke:visual:kards": "node tools/kards_browser_visual_smoke.mjs",
    "verify:dist-private-boundary": "node tools/verify_dist_private_boundary.mjs",
    "verify:private-tools": "node tools/run_private_tool_contracts.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false && tsc --noEmit -p tsconfig.node.json --pretty false",
    "validate": "npm test -- --run && npm run verify:private-tools && npm run build"
  },
  "dependencies": {
    "@fontsource/libre-franklin": "^5.2.8",
    "@fontsource/yantramanav": "^5.2.7",
    "@vercel/speed-insights": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
